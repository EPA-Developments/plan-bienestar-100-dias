{
  "name": "@epa/plan-bienestar-react",
  "version": "0.2.0",
  "description": "Modulo React drop-in del Plan Bienestar 100 Dias (salud cardiovascular en menopausia) para apps FooMedical / Medplum. Tarjeta auto-gating por PlanDefinition.useContext, rutas del plan y hooks de elegibilidad.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "fhir",
    "medplum",
    "foomedical",
    "react",
    "careplan",
    "menopause",
    "menopausia",
    "cardiovascular",
    "plan-bienestar-100-dias",
    "epa-bienestar"
  ],
  "dependencies": {
    "@epa/careplan-menopausia": "^0.3.0"
  },
  "peerDependencies": {
    "@mantine/core": ">=7.0.0",
    "@mantine/hooks": ">=7.0.0",
    "@mantine/notifications": ">=7.0.0",
    "@medplum/core": ">=3.1.0",
    "@medplum/fhirtypes": ">=3.1.0",
    "@medplum/react": ">=3.1.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router": ">=6.4.0"
  },
  "devDependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@medplum/core": "^5.1.24",
    "@medplum/definitions": "^5.1.24",
    "@medplum/fhirtypes": "^5.1.24",
    "@medplum/mock": "^5.1.24",
    "@medplum/react": "^5.1.24",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EPA-Developments/plan-bienestar-100-dias.git",
    "directory": "packages/plan-bienestar-react"
  }
}
